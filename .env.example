# Spotify API credentials — Proton Pass vault reference format.
# Copy this pattern into .env and replace the vault/item/field names to match your Proton Pass setup.
# Get the Spotify credentials from: https://developer.spotify.com/dashboard/
#
# Vault reference format:  pass://<vault-name>/<item-name>/<field-name>
#
SPOTIFY_CLIENT_ID=pass://Personal/Spotify API/client_id
SPOTIFY_CLIENT_SECRET=pass://Personal/Spotify API/client_secret