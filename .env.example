# Spotify API credentials — 1Password vault reference format.
# Copy this pattern into .env and replace the vault/item/field names to match your 1Password setup.
# Get the Spotify credentials from: https://developer.spotify.com/dashboard/
#
# Vault reference format:  op://<vault-name>/<item-name>/<field-name>
#
SPOTIFY_CLIENT_ID=op://Personal/Spotify API/client_id
SPOTIFY_CLIENT_SECRET=op://Personal/Spotify API/client_secret